# =========================================================================
# YAP environment configuration template
# =========================================================================

# Puerto en el que corre el servidor backend
PORT=3001

# URL de la aplicación frontend para CORS
FRONTEND_URL=http://localhost:5173

# Llave secreta para la firma y verificación de tokens JWT (CAMBIAR EN PRODUCCIÓN)
JWT_SECRET=tu_firma_secreta_yap_2026_reemplazar_con_algo_seguro

# API Key de Resend para notificaciones por correo (Opcional - usa simulación local si falta)
RESEND_API_KEY=re_123456789

# Credenciales de Supabase Storage para logotipos y PDFs (Opcional - usa almacenamiento local si falta)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-anon-key
